# Copy these names into Vercel Project Settings > Environment Variables.
# Do not commit real production values.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
JWT_SECRET="generate-a-long-random-secret-at-least-48-characters"
NEXT_PUBLIC_APP_URL="https://your-production-domain.example"

# Optional capabilities. Leave unset until the integration is configured.
# RESEND_API_KEY="re_..."
# FROM_EMAIL="PayNest <noreply@your-verified-domain.example>"
# CONTACT_EMAIL="support@your-domain.example"
# CRON_SECRET="generate-a-long-random-secret-at-least-32-characters"
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_token"

# Optional monitoring
SENTRY_DSN=""
UPTIME_HEALTHCHECK_URL="https://your-production-domain.example/api/health?strict=1"
