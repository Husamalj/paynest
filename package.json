{
  "name": "paynest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/check-tenant-isolation.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "check:env": "node scripts/check-production-env.mjs",
    "check:isolation": "node scripts/check-tenant-isolation.mjs",
    "test": "npm run test:e2e",
    "test:unit": "vitest run tests/unit",
    "test:unit:watch": "vitest tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/smoke",
    "test:e2e:auth": "playwright test tests/auth",
    "test:e2e:api": "playwright test tests/api",
    "test:e2e:rbac": "playwright test tests/rbac",
    "test:prepare": "tsx scripts/test-prepare.ts",
    "test:seed": "tsx scripts/test-seed.ts",
    "test:seed:users": "tsx scripts/seed-test-users.ts",
    "test:reset": "tsx scripts/test-reset.ts",
    "test:all": "npm run lint && npm run test:unit && npm run test:e2e:smoke",
    "test:install": "playwright install --with-deps chromium",
    "k6:smoke": "k6 run k6/homepage-smoke.js",
    "k6:normal": "k6 run k6/normal-day-load.js",
    "k6:employee": "k6 run k6/authenticated-employee-load.js",
    "k6:clockin": "k6 run k6/morning-clockin-spike.js",
    "k6:payroll": "k6 run k6/payroll-day.js",
    "k6:stress": "k6 run k6/stress.js",
    "k6:soak": "k6 run k6/soak.js",
    "zap:baseline": "node scripts/zap-baseline.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@react-pdf/renderer": "^4.5.1",
    "@xmldom/xmldom": "^0.9.10",
    "@xyflow/react": "^12.10.2",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "docx-preview": "^0.3.7",
    "docxtemplater": "^3.69.0",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.13.4",
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "pizzip": "^3.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.4",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.0.15"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
