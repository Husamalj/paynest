generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(255)
  slug          String   @unique @db.VarChar(100)
  status        String   @default("active") @db.VarChar(20)
  isActive      Boolean  @default(true) @map("is_active")
  maxEmployees        Int?     @map("max_employees")
  subscriptionPlan    String   @default("manual") @map("subscription_plan") @db.VarChar(50)
  subscriptionStatus  String   @default("active") @map("subscription_status") @db.VarChar(30)
  trialEndsAt         DateTime? @map("trial_ends_at")
  subscriptionEndsAt  DateTime? @map("subscription_ends_at")
  billingEmail        String?  @map("billing_email") @db.VarChar(255)
  billingNotes        String?  @map("billing_notes") @db.Text
  hiddenPages         Json     @default("[]") @map("hidden_pages")
  createdAt           DateTime @default(now()) @map("created_at")
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")

  users             User[]
  employees         Employee[]
  settings          CompanySettings[]
  attendanceRecords AttendanceRecord[]
  payrollRecords    PayrollRecord[]
  bonusesDeductions BonusDeduction[]
  uploadedFiles     UploadedFile[]
  leaveRequests     LeaveRequest[]
  leaveBalances     LeaveBalance[]
  officialHolidays  OfficialHoliday[]
  tasks              Task[]
  remoteAssignments  RemoteAssignment[]
  announcements      Announcement[]
  employeeDocuments  EmployeeDocument[]
  evaluations        Evaluation[]
  auditLogs          AuditLog[]
  notifications      Notification[]

  @@index([subscriptionStatus])
  @@map("companies")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  userId    Int      @map("user_id")
  userName  String?  @map("user_name") @db.VarChar(255)
  userRole  String?  @map("user_role") @db.VarChar(20)
  action    String   @db.VarChar(50)
  entity    String   @db.VarChar(50)
  entityId  String?  @map("entity_id") @db.VarChar(100)
  changes   Json?
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@map("audit_logs")
}

model User {
  id                 Int      @id @default(autoincrement())
  name               String   @db.VarChar(255)
  employeeNumber     String?  @map("employee_number") @db.VarChar(50)
  email              String?  @db.VarChar(255)
  password           String   @db.VarChar(255)
  role               String   @db.VarChar(20)
  isActive           Boolean  @default(true) @map("is_active")
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  companyId          Int?     @map("company_id")
  createdAt          DateTime @default(now()) @map("created_at")
  emailVerifiedAt    DateTime? @map("email_verified_at")

  company     Company?     @relation(fields: [companyId], references: [id])
  evaluations Evaluation[] @relation("EvaluatorEvaluations")

  @@index([companyId, role])
  @@map("users")
}

model CompanySettings {
  id            Int      @id @default(autoincrement())
  companyId     Int      @default(1) @map("company_id")
  companyName   String   @default("PayNest") @map("company_name") @db.VarChar(255)
  // systemMode = legacy identity bucket (kept "daily" for everyone now).
  // calcMode   = the payroll calculation method (daily/monthly vs hourly).
  systemMode    String   @default("daily") @map("system_mode") @db.VarChar(20)
  calcMode      String   @default("daily") @map("calc_mode") @db.VarChar(20)
  language      String   @default("ar") @db.VarChar(10)
  reqHours      Decimal  @default(8) @map("req_hours")
  monthDays     Int      @default(26) @map("month_days")
  lateTolerance Int      @default(0) @map("late_tolerance")
  workdays      String   @default("Sun,Mon,Tue,Wed,Thu") @db.VarChar(50)
  deductionRate Decimal  @default(1.0) @map("deduction_rate")
  extraRate     Decimal  @default(1.0) @map("extra_rate")
  workStartTime String   @default("09:00") @map("work_start_time") @db.VarChar(5)
  timezone      String   @default("Asia/Amman") @db.VarChar(60)
  // White-label branding (used in emails + UI)
  logo          String?  @db.Text
  brandColor    String?  @map("brand_color") @db.VarChar(20)
  emailFromName String?  @map("email_from_name") @db.VarChar(120)
  replyTo       String?  @map("reply_to") @db.VarChar(160)
  createdAt     DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("company_settings")
}

model Employee {
  id             Int      @id @default(autoincrement())
  companyId      Int      @default(1) @map("company_id")
  employeeId     String?  @map("employee_id") @db.VarChar(50)
  name           String   @db.VarChar(255)
  email          String   @default("") @db.VarChar(255)
  religion       String   @default("") @db.VarChar(50)
  baseSalary     Decimal  @default(0) @map("base_salary")
  phone          String   @default("") @db.VarChar(30)
  socialSecurity Boolean  @default(false) @map("social_security")
  remoteDays     Int      @default(0) @map("remote_days")
  allowance      Decimal  @default(0) @db.Decimal(10, 2)
  jobTitle       String?  @map("job_title") @db.VarChar(255)
  nationality    String?   @map("nationality") @db.VarChar(100)
  gender         String?   @map("gender") @db.VarChar(10)
  nationalId     String?   @map("national_id") @db.VarChar(50)
  birthDate      DateTime? @map("birth_date") @db.Date
  photoUrl       String?   @map("photo_url")
  joinDate        DateTime? @map("join_date") @db.Date
  contractEndDate DateTime? @map("contract_end_date") @db.Date
  department      String?   @map("department") @db.VarChar(50)
  departmentNumber String?  @map("department_number") @db.VarChar(50)
  systemMode     String   @default("daily") @map("system_mode") @db.VarChar(20)
  // Per-employee work schedule (override company defaults). null = use company setting.
  workType       String   @default("standard") @map("work_type") @db.VarChar(20) // standard | fixed
  workdays       String?  @db.VarChar(50)   // e.g. "Sat,Sun,Mon,Tue,Wed"
  reqHours       Decimal? @map("req_hours") // required hours per day
  supervisorId   Int?     @map("supervisor_id")
  supervisorIds  Int[]    @default([]) @map("supervisor_ids")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  company      Company    @relation(fields: [companyId], references: [id])
  supervisor   Employee?  @relation("EmployeeSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)
  subordinates Employee[] @relation("EmployeeSupervisor")

  // Identity is independent of the calculation system (monthly/hourly).
  // One record per person per company; systemMode is kept only as a legacy
  // default and is no longer part of the identity key.
  @@unique([employeeId, companyId], map: "employees_emp_company_uidx")
  @@index([companyId, name])
  @@index([companyId, department])
  @@index([supervisorId])
  @@map("employees")
}

model EmployeeDocument {
  id           Int      @id @default(autoincrement())
  companyId    Int      @map("company_id")
  employeeId   String   @map("employee_id") @db.VarChar(50)
  documentType String   @map("document_type") @db.VarChar(50)
  fileName     String   @map("file_name") @db.VarChar(255)
  fileData     String?  @map("file_data") @db.Text
  fileUrl      String?  @map("file_url") @db.Text
  fileStorageKey String? @map("file_storage_key") @db.Text
  mimeType     String?  @map("mime_type") @db.VarChar(150)
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, employeeId, uploadedAt])
  @@map("employee_documents")
}

model AttendanceRecord {
  id          Int       @id @default(autoincrement())
  companyId   Int       @default(1) @map("company_id")
  employeeId  String?   @map("employee_id") @db.VarChar(50)
  workDate    DateTime? @map("work_date") @db.Date
  clockIn     DateTime? @map("clock_in") @db.Time
  clockOut    DateTime? @map("clock_out") @db.Time
  hoursWorked Decimal   @default(0) @map("hours_worked")
  uploadBatch String?   @map("upload_batch") @db.VarChar(100)
  systemMode  String    @default("daily") @map("system_mode") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, workDate])
  @@index([companyId, employeeId, workDate])
  @@index([companyId, systemMode, workDate])
  @@map("attendance_records")
}

model PayrollRecord {
  id                   Int      @id @default(autoincrement())
  companyId            Int      @default(1) @map("company_id")
  employeeId           String?  @map("employee_id") @db.VarChar(50)
  periodMonth          Int?     @map("period_month")
  periodYear           Int?     @map("period_year")
  baseSalary           Decimal? @map("base_salary")
  totalHours           Decimal? @map("total_hours")
  requiredHours        Decimal? @map("required_hours")
  hourDiff             Decimal? @map("hour_diff")
  adjustment           Decimal?
  socialSecurityDeduct Decimal  @default(0) @map("social_security_deduct")
  bonusTotal           Decimal  @default(0) @map("bonus_total")
  deductionTotal       Decimal  @default(0) @map("deduction_total")
  netSalary            Decimal? @map("net_salary")
  status               String?  @db.VarChar(50)
  dailyBreakdown       Json?    @map("daily_breakdown")
  systemMode           String   @default("daily") @map("system_mode") @db.VarChar(20)
  calculatedAt         DateTime @default(now()) @map("calculated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, periodYear, periodMonth])
  @@index([companyId, employeeId, periodYear, periodMonth])
  @@index([companyId, systemMode, calculatedAt])
  @@map("payroll_records")
}

model PayrollJob {
  id            Int       @id @default(autoincrement())
  companyId     Int       @map("company_id")
  requestedBy   Int       @map("requested_by")
  periodMonth   Int       @map("period_month")
  periodYear    Int       @map("period_year")
  systemMode    String    @default("daily") @map("system_mode") @db.VarChar(20)
  status        String    @default("queued") @db.VarChar(20)
  processedRows Int       @default(0) @map("processed_rows")
  totalRows     Int       @default(0) @map("total_rows")
  error         String?
  resultSummary Json?     @map("result_summary")
  startedAt     DateTime? @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([companyId, status, createdAt])
  @@index([companyId, periodYear, periodMonth])
  @@map("payroll_jobs")
}

model BonusDeduction {
  id           Int      @id @default(autoincrement())
  companyId    Int      @default(1) @map("company_id")
  employeeId   String?  @map("employee_id") @db.VarChar(50)
  employeeName String?  @map("employee_name") @db.VarChar(255)
  type         String?  @db.VarChar(50)
  reason       String?  @db.VarChar(255)
  amount       Decimal?
  periodMonth  Int?     @map("period_month")
  periodYear   Int?     @map("period_year")
  systemMode   String   @default("daily") @map("system_mode") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, periodYear, periodMonth, employeeId])
  @@index([companyId, systemMode, createdAt])
  @@map("bonuses_deductions")
}

model UploadedFile {
  id            Int      @id @default(autoincrement())
  companyId     Int      @default(1) @map("company_id")
  filename      String?  @db.VarChar(255)
  originalName  String?  @map("original_name") @db.VarChar(255)
  fileType      String?  @map("file_type") @db.VarChar(50)
  uploadBatch   String?  @map("upload_batch") @db.VarChar(100)
  rowCount      Int?     @map("row_count")
  employeeCount Int      @default(0) @map("employee_count")
  systemMode    String   @default("daily") @map("system_mode") @db.VarChar(20)
  // Original uploaded file kept (base64) so HR can re-download it if the local
  // copy is lost. Nullable: files uploaded before this feature have no bytes.
  fileData      String?  @map("file_data") @db.Text
  fileUrl       String?  @map("file_url") @db.Text
  fileStorageKey String? @map("file_storage_key") @db.Text
  mimeType      String?  @map("mime_type") @db.VarChar(150)
  // The month/year this file's data belongs to (a label, independent of the
  // upload date — e.g. a May payroll file uploaded in June).
  periodMonth   Int?     @map("period_month")
  periodYear    Int?     @map("period_year")
  createdAt     DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, systemMode, createdAt])
  @@index([companyId, periodYear, periodMonth])
  @@map("uploaded_files")
}

model LeaveRequest {
  id           Int       @id @default(autoincrement())
  companyId    Int       @default(1) @map("company_id")
  employeeId   String?   @map("employee_id") @db.VarChar(50)
  employeeName String?   @map("employee_name") @db.VarChar(255)
  leaveType    String?   @map("leave_type") @db.VarChar(50)
  startDate    DateTime? @map("start_date") @db.Date
  endDate      DateTime? @map("end_date") @db.Date
  daysCount    Int?      @map("days_count")
  reason       String?
  status           String    @default("pending") @db.VarChar(20)
  supervisorStatus String    @default("pending") @map("supervisor_status") @db.VarChar(20)
  hrStatus         String    @default("pending") @map("hr_status") @db.VarChar(20)
  attachmentUrl    String?   @map("attachment_url") @db.Text
  adminNote        String?   @map("admin_note")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, status, createdAt])
  @@index([companyId, employeeId, startDate, endDate])
  @@map("leave_requests")
}

model LeaveBalance {
  id          Int     @id @default(autoincrement())
  companyId   Int     @default(1) @map("company_id")
  employeeId  String? @map("employee_id") @db.VarChar(50)
  year        Int?
  annualTotal Int     @default(14) @map("annual_total")
  annualUsed  Int     @default(0) @map("annual_used")
  sickTotal   Int     @default(14) @map("sick_total")
  sickUsed    Int     @default(0) @map("sick_used")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, employeeId, year], map: "leave_balances_company_employee_year_uidx")
  @@map("leave_balances")
}

model OfficialHoliday {
  id          Int      @id @default(autoincrement())
  companyId   Int      @default(1) @map("company_id")
  name        String?  @db.VarChar(255)
  holidayDate DateTime @map("holiday_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, holidayDate], map: "official_holidays_company_date_uidx")
  @@map("official_holidays")
}

/// Per-month salary snapshot. The salary file uploaded for a given month is the
/// definitive roster + salaries for THAT month — independent of other months.
model MonthlySalary {
  id             Int      @id @default(autoincrement())
  companyId      Int      @map("company_id")
  periodMonth    Int      @map("period_month")
  periodYear     Int      @map("period_year")
  employeeId     String   @map("employee_id") @db.VarChar(50)
  name           String   @db.VarChar(255)
  baseSalary     Decimal  @default(0) @map("base_salary")
  socialSecurity Boolean  @default(false) @map("social_security")
  systemMode     String   @default("daily") @map("system_mode") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([companyId, periodYear, periodMonth, employeeId, systemMode], map: "monthly_salary_period_emp_uidx")
  @@index([companyId, periodYear, periodMonth, systemMode])
  @@map("monthly_salaries")
}

model Task {
  id           Int       @id @default(autoincrement())
  companyId    Int       @default(1) @map("company_id")
  taskName     String    @map("task_name") @db.VarChar(255)
  employeeId   String?   @map("employee_id") @db.VarChar(50)
  startDate    DateTime? @map("start_date") @db.Date
  deadline     DateTime? @db.Date
  status       String    @default("pending") @db.VarChar(50)
  // urgent | high | medium | low  (assignment priority set by the supervisor)
  priority     String    @default("medium") @db.VarChar(20)
  // Optional measurable target (independent of evaluation/bonus)
  targetValue  Float?    @map("target_value")
  currentValue Float     @default(0) @map("current_value")
  unit         String?   @db.VarChar(30)
  attachment     String? @db.Text
  attachmentName String? @map("attachment_name") @db.VarChar(255)
  report         String? @db.Text  // employee's progress report to the supervisor
  reportAt       DateTime? @map("report_at")
  systemMode   String    @default("daily") @map("system_mode") @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, employeeId, status])
  @@index([companyId, createdAt])
  @@map("tasks")
}

model RemoteAssignment {
  id         Int      @id @default(autoincrement())
  companyId  Int      @default(1) @map("company_id")
  employeeId String   @map("employee_id") @db.VarChar(50)
  startDate  DateTime @map("start_date") @db.Date
  endDate    DateTime @map("end_date") @db.Date
  label      String?  @db.VarChar(255)
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, employeeId, startDate, endDate], map: "remote_assignments_company_employee_dates_uidx")
  @@map("remote_assignments")
}

model Evaluation {
  id                    Int      @id @default(autoincrement())
  companyId             Int      @default(1) @map("company_id")
  evaluatorId           Int      @map("evaluator_id")
  employeeId            String   @map("employee_id") @db.VarChar(50)
  periodMonth           Int      @map("period_month")
  periodYear            Int      @map("period_year")
  scoreAccuracy         Int?     @map("score_accuracy") @db.SmallInt
  scoreInnovation       Int?     @map("score_innovation") @db.SmallInt
  scoreSpeed            Int?     @map("score_speed") @db.SmallInt
  scoreDevelopment      Int?     @map("score_development") @db.SmallInt
  scoreQualityCheck     Int?     @map("score_quality_check") @db.SmallInt
  scorePrioritization   Int?     @map("score_prioritization") @db.SmallInt
  scoreIndependence     Int?     @map("score_independence") @db.SmallInt
  scoreDeadlines        Int?     @map("score_deadlines") @db.SmallInt
  scoreTeamwork         Int?     @map("score_teamwork") @db.SmallInt
  scoreCommunication    Int?     @map("score_communication") @db.SmallInt
  scoreKnowledgeSharing Int?     @map("score_knowledge_sharing") @db.SmallInt
  scoreFeedback         Int?     @map("score_feedback") @db.SmallInt
  scoreCompliance       Int?     @map("score_compliance") @db.SmallInt
  bonusWorthy           Boolean  @default(false) @map("bonus_worthy")
  bonusAmount           Int      @default(0) @map("bonus_amount")
  // HR set a manual bonus for this employee (an exception). When true the
  // tier-based amount no longer overwrites it.
  bonusOverride         Boolean  @default(false) @map("bonus_override")
  recommendations       String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  company   Company @relation(fields: [companyId], references: [id])
  evaluator User    @relation("EvaluatorEvaluations", fields: [evaluatorId], references: [id])

  @@unique([companyId, evaluatorId, employeeId, periodMonth, periodYear])
  @@map("evaluations")
}

model BonusTier {
  id        Int      @id @default(autoincrement())
  companyId Int      @default(1) @map("company_id")
  minGrade  Int      @map("min_grade")
  maxGrade  Int      @map("max_grade")
  amount    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([companyId, minGrade])
  @@map("bonus_tiers")
}

model JobOffer {
  id                  Int      @id @default(autoincrement())
  companyId           Int      @default(1) @map("company_id")
  createdBy           Int      @map("created_by")
  // Personal information
  name                String?
  nationality         String?
  phone1              String?
  phone2              String?
  nationalId          String?  @map("national_id")
  qualifications      String?
  experience          String?
  offerDate           String?  @map("offer_date")
  // Training details
  trainingTitle       String?  @map("training_title")
  sector              String?
  trainingHours       String?  @map("training_hours")
  trainingPeriod      String?  @map("training_period")
  agreementDuration   String?  @map("agreement_duration")
  agreementType       String?  @map("agreement_type")
  agreementConditions String?  @map("agreement_conditions")
  // Benefits
  grantFirst          String?  @map("grant_first")
  grantSecond         String?  @map("grant_second")
  noteSecond          String?  @map("note_second")
  // Validity
  offerValidity       String?  @map("offer_validity")
  joiningDate         String?  @map("joining_date")
  // Applicant approval
  signatureDate       String?  @map("signature_date")
  fullName            String?  @map("full_name")
  // Free-field offers (per-company uploaded template): values keyed by field id
  values              Json?
  // "form" = built-in structured form (named columns); "word" = Word template (values)
  kind                String   @default("form") @db.VarChar(20)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([companyId, createdAt])
  @@map("job_offers")
}

// Platform-level demo/contact requests from the public landing form.
model ContactRequest {
  id        Int      @id @default(autoincrement())
  firstName String   @map("first_name") @db.VarChar(120)
  lastName  String?  @map("last_name") @db.VarChar(120)
  email     String   @db.VarChar(160)
  company   String?  @db.VarChar(200)
  teamSize  String?  @map("team_size") @db.VarChar(40)
  message   String?  @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([read, createdAt])
  @@map("contact_requests")
}

// Per-company training-offer template: a contract image + overlay field defs.
model JobOfferTemplate {
  id        Int      @id @default(autoincrement())
  companyId Int      @unique @map("company_id")
  image     String   @db.Text
  fields    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("job_offer_templates")
}

model Announcement {
  id                 Int      @id @default(autoincrement())
  companyId          Int      @default(1) @map("company_id")
  title              String   @db.VarChar(255)
  message            String
  published          Boolean  @default(false)
  visibleToEmployees Boolean  @default(true) @map("visible_to_employees")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, published, createdAt])
  @@map("announcements")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique @db.VarChar(64)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@map("password_reset_tokens")
}

model Notification {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  userId    Int?     @map("user_id")
  type      String   @db.VarChar(50)
  message   String
  link      String?  @db.VarChar(255)
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, read, createdAt])
  @@map("notifications")
}

model AdvanceRequest {
  id           Int       @id @default(autoincrement())
  companyId    Int       @map("company_id")
  employeeId   String?   @map("employee_id") @db.VarChar(50)
  employeeName String?   @map("employee_name") @db.VarChar(255)
  amount       Decimal
  installments Int       @default(1)
  reason       String?   @db.VarChar(500)
  status       String    @default("pending") @db.VarChar(20)
  adminNote    String?   @map("admin_note") @db.VarChar(500)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([companyId, status, createdAt])
  @@index([companyId, employeeId, createdAt])
  @@map("advance_requests")
}

// Private 1-to-1 messages between two people of the same company. Only the
// sender and receiver can read them — HR/owner have no special access.
model Message {
  id             Int      @id @default(autoincrement())
  companyId      Int      @map("company_id")
  senderId       String   @map("sender_id") @db.VarChar(50)
  receiverId     String   @map("receiver_id") @db.VarChar(50)
  body           String?
  attachment     String?  @db.Text
  attachmentName String?  @map("attachment_name") @db.VarChar(255)
  read           Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([companyId, senderId, receiverId, createdAt])
  @@index([companyId, receiverId, read])
  @@map("messages")
}

model CompanyEvent {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  eventDate DateTime @map("event_date") @db.Date
  title     String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([companyId, eventDate])
  @@map("company_events")
}

// HR-defined custom request type, scoped to a company. `fields` is a JSON array
// of { key, label, type: text|textarea|number|date|file, required }.
model RequestType {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  name      String   @db.VarChar(255)
  fields    Json     @default("[]")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([companyId, active])
  @@map("request_types")
}

// An employee's submission of a custom request type. `values` is a JSON object
// keyed by the type's field keys.
model CustomRequest {
  id            Int      @id @default(autoincrement())
  companyId     Int      @map("company_id")
  requestTypeId Int      @map("request_type_id")
  typeName      String   @map("type_name") @db.VarChar(255)
  employeeId    String?  @map("employee_id") @db.VarChar(50)
  employeeName  String?  @map("employee_name") @db.VarChar(255)
  values        Json     @default("{}")
  status        String   @default("pending") @db.VarChar(20)
  adminNote     String?  @map("admin_note")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([companyId, status])
  @@map("custom_requests")
}
