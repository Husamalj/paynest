# Copy these names into a dedicated Vercel staging/preview project.
# Never point staging load/security tests at production.

NODE_ENV="production"
DATABASE_URL="postgresql://STAGING_USER:STAGING_PASSWORD@STAGING_HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://STAGING_USER:STAGING_PASSWORD@STAGING_HOST:5432/postgres"
JWT_SECRET="generate-a-long-random-secret-at-least-48-characters"
NEXT_PUBLIC_APP_URL="https://paynest-staging.example.com"
RESEND_API_KEY="re_staging_or_test_key"
FROM_EMAIL="PayNest Staging <noreply@your-verified-domain.example>"
CONTACT_EMAIL="support@your-domain.example"
CRON_SECRET="generate-a-long-random-secret-at-least-32-characters"

# E2E/staging tests
PAYNEST_ALLOW_TEST_DB="true"
PAYNEST_TEST_DB_READY="true"
PLAYWRIGHT_BASE_URL="https://paynest-staging.example.com"

# k6 staging users
K6_BASE_URL="https://paynest-staging.example.com"
K6_EMPLOYEE_EMAIL="employee@demo.paynest.app"
K6_EMPLOYEE_PASSWORD="replace-with-staging-demo-password"
K6_OWNER_EMAIL="owner@demo.paynest.app"
K6_OWNER_PASSWORD="replace-with-staging-demo-password"

