# Copy to .env.test for local tests. Never point these values at production.
NODE_ENV="test"
PAYNEST_ALLOW_TEST_DB="true"

# Use a disposable local/staging test database only.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/paynest_test"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/paynest_test"
TEST_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/paynest_test"
TEST_DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/paynest_test"

JWT_SECRET="test-jwt-secret-change-me"
NEXT_PUBLIC_SITE_URL="http://127.0.0.1:3000"
PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"

PAYNEST_TEST_PASSWORD="Test123!"
PAYNEST_TEST_EMPLOYEE_EMAIL="employee@test.com"
PAYNEST_TEST_EMPLOYEE_PASSWORD="Test123!"
PAYNEST_TEST_HR_EMAIL="hr@test.com"
PAYNEST_TEST_HR_PASSWORD="Test123!"
PAYNEST_TEST_OWNER_EMAIL="owner@test.com"
PAYNEST_TEST_OWNER_PASSWORD="Test123!"
PAYNEST_TEST_SUPER_ADMIN_EMAIL="superadmin@test.com"
PAYNEST_TEST_SUPER_ADMIN_PASSWORD="Test123!"

# Stubbed/non-production email settings.
RESEND_API_KEY="test-resend-disabled"
FROM_EMAIL="noreply@example.test"
CONTACT_EMAIL="security@example.test"

# k6 must target staging/non-production.
K6_BASE_URL="https://staging.paynest.example"
K6_EMPLOYEE_EMAIL="employee@test.com"
K6_EMPLOYEE_PASSWORD="Test123!"
K6_OWNER_EMAIL="owner@test.com"
K6_OWNER_PASSWORD="Test123!"
