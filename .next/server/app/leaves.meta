{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/leaves/layout,_N_T_/(app)/leaves/page,_N_T_/leaves"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/leaves/__PAGE__",
    "/!KGFwcCk/leaves",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}