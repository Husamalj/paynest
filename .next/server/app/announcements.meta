{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/announcements/layout,_N_T_/(app)/announcements/page,_N_T_/announcements"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/announcements/__PAGE__",
    "/!KGFwcCk/announcements",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}